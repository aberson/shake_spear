{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ss: new-story",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "new-story", "${input:storyTitle}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: session",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "session", "${input:projectSlug}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: index",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "index", "${input:projectSlug}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: recap",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "recap", "${input:projectSlug}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: status",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "status", "${input:projectSlug}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: list-projects",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "list-projects"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "ss: export",
      "type": "shell",
      "command": "uv",
      "args": ["run", "ss", "export", "${input:projectSlug}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": []
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "uv",
      "args": ["run", "pytest"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "storyTitle",
      "type": "promptString",
      "description": "Title for the new story, e.g. Kids Space Bakery"
    },
    {
      "id": "projectSlug",
      "type": "promptString",
      "description": "Story project slug, e.g. kids_space_bakery"
    }
  ]
}
