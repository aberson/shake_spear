# All markdown (templates now, skills/*.md next step) is read at runtime with
# newline="\n" (plan §3.4); CLAUDE.md pins LF for all I/O. Pin LF repo-wide so
# core.autocrlf=true checkouts cannot convert to CRLF.
*.md text eol=lf
*.py text eol=lf
# The committed sample story (plan §11 Step 13) ships .gitignore/.gitkeep
# files and tests/test_sample_story.py asserts every one of its files is LF.
.gitignore text eol=lf
.gitkeep text eol=lf
